{
  "mcpServers": {
    "prometheus": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--network=host",
        "-e",
        "PROMETHEUS_MCP_SERVER_PROMETHEUS_URL=http://localhost:9090",
        "ghcr.io/tjhop/prometheus-mcp-server:latest"
      ],
      "env": {
        "PROMETHEUS_MCP_SERVER_WEB_LISTEN_ADDRESS": ":8181"
      }
    }
  }
}