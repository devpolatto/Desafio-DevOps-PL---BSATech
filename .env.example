# =============================================================
# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env
#
# NUNCA commitar o .env com credenciais reais.
# =============================================================

# --- MySQL ---
# Senha do usuário root (usada apenas internamente pelo container)
MYSQL_ROOT_PASSWORD=changeme_root_password

# Nome do banco de dados do Ghost
MYSQL_DATABASE=ghostdb

# Usuário da aplicação (usado pelo Ghost para conectar)
MYSQL_USER=ghost

# Senha do usuário da aplicação
MYSQL_PASSWORD=changeme_ghost_password

# --- Ghost ---
# URL pública do blog (deve ser HTTPS em produção)
GHOST_URL=https://localhost

# --- Grafana ---
# Senha do admin do Grafana (usuário: admin)
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
